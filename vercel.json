{
  "version": 2,
  "framework": "vite",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(assets/.*)",
      "destination": "frontend/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
